@model List<InterviewAI.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-people me-2"></i>All Registered Users</h4>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th><i class="bi bi-hash me-1"></i> #</th>
                                <th><i class="bi bi-person me-1"></i> Name</th>
                                <th><i class="bi bi-envelope me-1"></i> Email</th>
                                <th><i class="bi bi-shield me-1"></i> Role</th>
                                <th><i class="bi bi-gear me-1"></i> Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td><strong>@(i + 1)</strong></td>
                                    <td>
                                        <i class="bi bi-person-circle me-2 text-muted"></i>
                                        @Model[i].Name
                                    </td>
                                    <td>@Model[i].Email</td>
                                    <td>
                                        @if (Model[i].Role?.ToLower() == "admin")
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-shield-fill me-1"></i>Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-person me-1"></i>Student</span>
                                        }
                                    </td>
                                    <td>
                                        @if (Model[i].Role?.ToLower() != "admin")
                                        {
                                            <a href="/Account/MakeAdmin?email=@Uri.EscapeDataString(Model[i].Email)" 
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Make @Model[i].Email an Admin?');">
                                                <i class="bi bi-arrow-up-circle"></i> Make Admin
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="bi bi-check-circle me-1"></i>Admin</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="card bg-light mt-3">
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-4">
                                <h5><i class="bi bi-people text-primary me-2"></i>Total Users</h5>
                                <p class="h3">@Model.Count</p>
                            </div>
                            <div class="col-md-4">
                                <h5><i class="bi bi-shield-fill text-danger me-2"></i>Admins</h5>
                                <p class="h3">@Model.Count(x => x.Role?.ToLower() == "admin")</p>
                            </div>
                            <div class="col-md-4">
                                <h5><i class="bi bi-person text-secondary me-2"></i>Students</h5>
                                <p class="h3">@Model.Count(x => x.Role?.ToLower() != "admin")</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-people display-4 mb-3 text-info"></i>
                    <h4>No Users Found</h4>
                    <p>There are no registered users in the system.</p>
                </div>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a href="/Account/Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</div>
