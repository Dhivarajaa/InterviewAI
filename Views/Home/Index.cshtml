@{
    ViewData["Title"] = "InterviewAI - Smart Interview Preparation";
}

<div class="container">
    <!-- Hero Section -->
    <div class="hero-section text-center mb-5">
        <h1 class="display-3 fw-bold mb-3">
            <span class="text-gradient">InterviewAI</span>
        </h1>
        <p class="lead fs-3 mb-4">AI-Powered Interview Question Generator</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="/Account/Register" class="btn btn-danger btn-lg px-5">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started
            </a>
            <a href="/Account/Login" class="btn btn-outline-light btn-lg px-5">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </a>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 text-center p-4">
                <div class="card-body">
                    <div class="icon-box mb-3">
                        <i class="bi bi-robot display-1 text-danger"></i>
                    </div>
                    <h4 class="card-title fw-bold">AI Question Generator</h4>
                    <p class="card-text text-muted">Generate personalized interview questions based on your selected domain, difficulty level, and keywords.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center p-4">
                <div class="card-body">
                    <div class="icon-box mb-3">
                        <i class="bi bi-mortarboard display-1 text-success"></i>
                    </div>
                    <h4 class="card-title fw-bold">Interview Preparation</h4>
                    <p class="card-text text-muted">Prepare for your next interview with comprehensive question sets covering C#, AI, DBMS, and more.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center p-4">
                <div class="card-body">
                    <div class="icon-box mb-3">
                        <i class="bi bi-graph-up display-1 text-info"></i>
                    </div>
                    <h4 class="card-title fw-bold">Track Progress</h4>
                    <p class="card-text text-muted">Monitor your performance and see your improvement over time with detailed analytics.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact & Features Section -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-envelope me-2"></i>Contact Us</h4>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <input type="text" class="form-control form-control-lg" placeholder="Your Name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" class="form-control form-control-lg" placeholder="your.email@example.com">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Message</label>
                            <textarea class="form-control" rows="4" placeholder="Your message..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-send me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-star me-2"></i>Features</h4>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check-circle text-success me-3 fs-4"></i>
                            <span>Generate questions by domain</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check-circle text-success me-3 fs-4"></i>
                            <span>Select difficulty level</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check-circle text-success me-3 fs-4"></i>
                            <span>Filter by keywords</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check-circle text-success me-3 fs-4"></i>
                            <span>Multiple domains supported</span>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="bi bi-check-circle text-success me-3 fs-4"></i>
                            <span>Track test history</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
