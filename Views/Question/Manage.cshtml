@model List<InterviewAI.Models.Question>

@{
    ViewData["Title"] = "Manage Questions";
}

<div class="container">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2><i class="bi bi-gear"></i> Manage Questions</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Question/Add" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add New Question
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Question</th>
                        <th>Options</th>
                        <th>Answer</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td><strong>@(i + 1)</strong></td>
                            <td>@Model[i].QuestionText</td>
                            <td>
                                <small>
                                    A: @Model[i].OptionA<br />
                                    B: @Model[i].OptionB<br />
                                    C: @Model[i].OptionC<br />
                                    D: @Model[i].OptionD
                                </small>
                            </td>
                            <td>
                                <span class="badge bg-success">@Model[i].CorrectAnswer</span>
                            </td>
                            <td>
                                <a href="/Question/Edit/@Model[i].Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="/Question/Delete/@Model[i].Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="card bg-light">
            <div class="card-body">
                <strong>Total Questions:</strong> @Model.Count
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <h4><i class="bi bi-info-circle"></i> No Questions Yet</h4>
            <p>There are no questions in the database. Click the button below to add your first question.</p>
            <a href="/Question/Add" class="btn btn-success">Add First Question</a>
        </div>
    }
</div>
