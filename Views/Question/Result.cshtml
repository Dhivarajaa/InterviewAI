@{
    ViewData["Title"] = "Test Result";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @if (ViewBag.ResultMessage == "PASS")
            {
                <div class="card border-success shadow">
                    <div class="card-header bg-success text-white text-center">
                        <h2 class="mb-0"><i class="bi bi-check-circle-fill"></i> PASS</h2>
                    </div>
                    <div class="card-body text-center">
                        <div class="display-1 text-success mb-3">@ViewBag.Score/@ViewBag.Total</div>
                        <div class="h2">@ViewBag.Percentage.ToString("F1")%</div>
                        <hr />
                        <p class="lead">Congratulations! You passed the test!</p>
                        <div class="progress mb-3" style="height: 30px;">
                            <div class="progress-bar bg-success" style="width: @ViewBag.Percentage%">
                                @ViewBag.Percentage.ToString("F1")%
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-danger shadow">
                    <div class="card-header bg-danger text-white text-center">
                        <h2 class="mb-0"><i class="bi bi-x-circle-fill"></i> FAIL</h2>
                    </div>
                    <div class="card-body text-center">
                        <div class="display-1 text-danger mb-3">@ViewBag.Score/@ViewBag.Total</div>
                        <div class="h2">@ViewBag.Percentage.ToString("F1")%</div>
                        <hr />
                        <p class="lead">Keep practicing! You need 50% to pass.</p>
                        <div class="progress mb-3" style="height: 30px;">
                            <div class="progress-bar bg-danger" style="width: @ViewBag.Percentage%">
                                @ViewBag.Percentage.ToString("F1")%
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-grid gap-2 mt-4">
                <a href="/Question/TakeTest" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-repeat"></i> Take Test Again
                </a>
                <a href="/Question/History" class="btn btn-secondary">
                    <i class="bi bi-clock-history"></i> View History
                </a>
                <a href="/Account/Dashboard" class="btn btn-outline-secondary">
                    <i class="bi bi-house"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
