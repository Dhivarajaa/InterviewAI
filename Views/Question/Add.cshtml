@model InterviewAI.Models.Question

@{
    ViewData["Title"] = "Add Question";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Add New Question</h4>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Add" method="post">
                        <div class="mb-3">
                            <label class="form-label"><strong>Question Text</strong></label>
                            <textarea name="QuestionText" class="form-control" rows="3" placeholder="Enter your question here..." required>@Model?.QuestionText</textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>A.</strong></label>
                                <input type="text" name="OptionA" class="form-control" placeholder="First option" required value="@Model?.OptionA">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>B.</strong></label>
                                <input type="text" name="OptionB" class="form-control" placeholder="Second option" required value="@Model?.OptionB">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>C.</strong></label>
                                <input type="text" name="OptionC" class="form-control" placeholder="Third option" required value="@Model?.OptionC">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><strong>D.</strong></label>
                                <input type="text" name="OptionD" class="form-control" placeholder="Fourth option" required value="@Model?.OptionD">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><strong>Correct Answer</strong></label>
                            <select name="CorrectAnswer" class="form-select" required>
                                <option value="">Select correct answer</option>
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/Question/Manage" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Save Question
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
