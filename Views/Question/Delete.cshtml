@model InterviewAI.Models.Question

@{
    ViewData["Title"] = "Delete Question";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h4>
                </div>
                <div class="card-body">
                    <h5>Are you sure you want to delete this question?</h5>
                    <hr />
                    <p><strong>Question:</strong> @Model.QuestionText</p>
                    <p><strong>A.</strong> @Model.OptionA</p>
                    <p><strong>B.</strong> @Model.OptionB</p>
                    <p><strong>C.</strong> @Model.OptionC</p>
                    <p><strong>D.</strong> @Model.OptionD</p>
                    <p><strong>Correct Answer:</strong> <span class="badge bg-success">@Model.CorrectAnswer</span></p>
                    
                    <hr />
                    
                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Delete Question
                            </button>
                            <a href="/Question/Manage" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
