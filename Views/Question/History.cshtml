@model List<InterviewAI.Models.TestResult>

@{
    ViewData["Title"] = "My Test History";
}

<div class="container">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i>My Test History</h4>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th><i class="bi bi-calendar me-1"></i> Date</th>
                                <th><i class="bi bi-check-circle me-1"></i> Score</th>
                                <th><i class="bi bi-list-ol me-1"></i> Total</th>
                                <th><i class="bi bi-percent me-1"></i> Percentage</th>
                                <th><i class="bi bi-info-circle me-1"></i> Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.DateTaken.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td><strong>@item.Score</strong></td>
                                    <td>@item.TotalQuestions</td>
                                    <td>
                                        <span class="badge @(item.Percentage >= 50 ? "bg-success" : "bg-danger")">
                                            @item.Percentage.ToString("F1")%
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.Percentage >= 50)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> PASS</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-lg"></i> FAIL</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="card bg-light mt-3">
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-4">
                                <h5><i class="bi bi-list-check text-primary me-2"></i>Total Tests</h5>
                                <p class="h3">@Model.Count</p>
                            </div>
                            <div class="col-md-4">
                                <h5><i class="bi bi-trophy text-warning me-2"></i>Best Score</h5>
                                <p class="h3">@Model.Max(x => x.Percentage).ToString("F1")%</p>
                            </div>
                            <div class="col-md-4">
                                <h5><i class="bi bi-graph-up text-success me-2"></i>Average</h5>
                                <p class="h3">@Model.Average(x => x.Percentage).ToString("F1")%</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle-fill display-4 mb-3"></i>
                    <h4>No Test History Yet</h4>
                    <p>You haven't taken any tests yet. Start a test to see your history here!</p>
                    <a href="/Question/TakeTest" class="btn btn-primary">
                        <i class="bi bi-play-circle me-2"></i>Take Test
                    </a>
                </div>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a href="/Account/Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</div>
