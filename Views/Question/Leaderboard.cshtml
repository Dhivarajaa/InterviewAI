@model List<InterviewAI.Models.TestResult>

@{
    ViewData["Title"] = "Leaderboard";
}

<div class="container">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="bi bi-trophy me-2"></i>Leaderboard</h4>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th><i class="bi bi-award me-1"></i> Rank</th>
                                <th><i class="bi bi-person-circle me-1"></i> User</th>
                                <th><i class="bi bi-check-circle me-1"></i> Score</th>
                                <th><i class="bi bi-list-ol me-1"></i> Total</th>
                                <th><i class="bi bi-percent me-1"></i> Percentage</th>
                                <th><i class="bi bi-calendar me-1"></i> Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rank = 1;
                            }
                            @foreach (var item in Model.OrderByDescending(x => x.Percentage).ThenByDescending(x => x.Score))
                            {
                                <tr class="@(rank == 1 ? "table-warning" : rank == 2 ? "table-secondary" : rank == 3 ? "tableBronze" : "")">
                                    <td>
                                        @if (rank == 1)
                                        {
                                            <span class="badge bg-warning text-dark fs-5"><i class="bi bi-trophy-fill"></i> 1st</span>
                                        }
                                        else if (rank == 2)
                                        {
                                            <span class="badge bg-secondary fs-5"><i class="bi bi-trophy"></i> 2nd</span>
                                        }
                                        else if (rank == 3)
                                        {
                                            <span class="badge" style="background-color: #CD7F32; color: white;"><i class="bi bi-trophy"></i> 3rd</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark">@rank</span>
                                        }
                                    </td>
                                    <td><i class="bi bi-envelope me-2 text-muted"></i>@item.UserEmail</td>
                                    <td><strong class="text-success">@item.Score</strong></td>
                                    <td>@item.TotalQuestions</td>
                                    <td>
                                        <span class="badge @(item.Percentage >= 50 ? "bg-success" : "bg-danger") fs-6">
                                            @item.Percentage.ToString("F1")%
                                        </span>
                                    </td>
                                    <td>@item.DateTaken.ToString("MMM dd, yyyy")</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="card bg-light mt-3">
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-md-6">
                                <h5><i class="bi bi-people text-primary me-2"></i>Total Participants</h5>
                                <p class="h3">@Model.Select(x => x.UserEmail).Distinct().Count()</p>
                            </div>
                            <div class="col-md-6">
                                <h5><i class="bi bi-graph-up-arrow text-success me-2"></i>Average Score</h5>
                                <p class="h3">@Model.Average(x => x.Percentage).ToString("F1")%</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-trophy display-4 mb-3 text-warning"></i>
                    <h4>No Results Yet</h4>
                    <p>Be the first to take a test and appear on the leaderboard!</p>
                    <a href="/Question/TakeTest" class="btn btn-primary">
                        <i class="bi bi-play-circle me-2"></i>Take Test
                    </a>
                </div>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a href="/Account/Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</div>

<style>
    .tableBronze {
        background-color: rgba(205, 127, 50, 0.1) !important;
    }
</style>
